# Django Configuration
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (SQLite for development, PostgreSQL for production)
# SQLite (default)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (uncomment and configure for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/pgfinder

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_EMBED_API_KEY=your-google-maps-embed-api-key

# PhonePe UPI Payment Gateway Configuration
PHONEPE_MERCHANT_ID=your-merchant-id
PHONEPE_API_KEY=your-api-key
PHONEPE_API_SECRET=your-api-secret
PHONEPE_ENVIRONMENT=SANDBOX

# Environment: SANDBOX or PRODUCTION
ENVIRONMENT=development

# Django Apps
DJANGO_SETTINGS_MODULE=PgFinder.settings

# Redis Configuration (for Chat System)
USE_REDIS=False
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging
LOG_LEVEL=INFO

# CSRF and Security
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Sentry Error Tracking (Optional)
SENTRY_DSN=
